# ============================
# Unreal Engine 5 - .gitignore
# ============================

# Cartelle generate automaticamente da UE (NON versionare)
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/
Content/StarterContent/

# Cartelle generate da tool esterni / IDE
.vs/
.vscode/
.idea/
*.opensdf
*.sdf
*.opendb
*.VC.db
*.VC.VC.opendb

# File di progetto Visual Studio generati automaticamente
*.sln
*.suo
*.xcodeproj
*.xcworkspace

# File temporanei del sistema operativo
.DS_Store
Thumbs.db
*.tmp

# File di log
*.log

# Cartelle di packaging/build
Saved/StagedBuilds/
Saved/Cooked/
Saved/Logs/
Saved/Crashes/
Saved/Config/

# Plugins compilati (se non vuoi versionare i binari dei plugin)
Plugins/*/Binaries/
Plugins/*/Intermediate/

# File generati da Rider/CLion (se usati come IDE)
.idea/

# Cartelle di cache Unreal Swarm/Lightmass
*.dmp
*.mdmp

# File temporanei creati da crash reporter
CrashReportClient/